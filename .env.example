# Clave de acceso a la app (la que se pide en la pantalla de login).
# Ponle cualquier frase o clave que quieras, solo tú (y quien tú decidas) la sabrá.
APP_PASSWORD=

# Frase secreta usada para firmar la cookie de sesión (no la comparte nadie, invéntala).
# Puede ser cualquier texto largo y aleatorio.
SESSION_SECRET=

# Datos del proyecto de Supabase (Project Settings > Data API / API Keys).
SUPABASE_URL=
SUPABASE_SECRET_KEY=
